{
  "name": "ripple-stick-to-bottom",
  "version": "0.2.0",
  "description": "Ripple/TSRX stick-to-bottom scroll primitives for streaming content.",
  "type": "module",
  "license": "MIT",
  "author": "ethan-huo",
  "homepage": "https://github.com/ethan-huo/ripple-stick-to-bottom#readme",
  "repository": "https://github.com/ethan-huo/ripple-stick-to-bottom",
  "bugs": {
    "url": "https://github.com/ethan-huo/ripple-stick-to-bottom/issues"
  },
  "keywords": [
    "ripple",
    "tsrx",
    "stick-to-bottom",
    "scroll",
    "streaming",
    "chat"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/stick-to-bottom.d.ts",
      "browser": "./dist/stick-to-bottom.client.js",
      "worker": "./dist/stick-to-bottom.server.js",
      "default": "./dist/stick-to-bottom.server.js"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "default": "./dist/controller.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun scripts/build.ts && tsc src/controller.ts --declaration --emitDeclarationOnly --outDir dist --skipLibCheck --moduleResolution bundler --module esnext --target esnext && cp types/stick-to-bottom.d.ts dist/stick-to-bottom.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ripple": ">=0.3.0"
  },
  "devDependencies": {
    "@tsrx/ripple": "^0.1.32",
    "ripple": "^0.3.84",
    "typescript": "^5.9.2"
  }
}
